# Backend API — must include /v1 (createOpenAI appends /chat/completions)
BACKEND_API_URL=http://localhost:8000/v1

# Access control — max uses per code before it's exhausted
MAX_CODE_USES=5

# In-app rate limiting (requests per window, defaults shown)
# RATE_LIMIT_VERIFY=5
# RATE_LIMIT_REQUEST=2
# RATE_LIMIT_CHAT=20

# Cloudflare D1 (for access control)
# Get these from Cloudflare dashboard → D1 → your database
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_API_TOKEN=
